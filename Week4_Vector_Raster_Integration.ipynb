{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Week 4: Vector & Raster Integration\n",
    "\n",
    "**This week you will:**\n",
    "1. Master vector aggregation (dissolve & groupby)\n",
    "2. Understand raster data as NumPy arrays with spatial metadata\n",
    "3. Compute terrain slope from DEM\n",
    "4. Extract raster values into vector shapes (zonal statistics)\n",
    "\n",
    "**Packages needed:** `geopandas`, `rioxarray`, `rasterstats`, `numpy`, `matplotlib`"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Setup & Package Installation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Install required packages (run once)\n",
    "# !pip install rioxarray rasterstats geopandas folium mapclassify matplotlib\n",
    "\n",
    "import geopandas as gpd\n",
    "import rioxarray as rxr\n",
    "import rasterstats\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import pandas as pd\n",
    "from shapely.geometry import Point\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "print(\"✅ All packages imported successfully!\")\n",
    "print(f\"geopandas: {gpd.__version__}\")\n",
    "print(f\"rioxarray: {rxr.__version__}\")\n",
    "print(f\"rasterstats: {rasterstats.__version__}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Lab 1: Vector Aggregation (Review)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load township data\n",
    "townships = gpd.read_file('TOWN_MOI_1120317.shp')\n",
    "print(f\"Loaded {len(townships)} townships\")\n",
    "print(f\"CRS: {townships.crs}\")\n",
    "\n",
    "# Dissolve townships to counties\n",
    "counties = townships.dissolve(by='COUNTYNAME', aggfunc='first')\n",
    "print(f\"Dissolved to {len(counties)} counties\")\n",
    "\n",
    "# Plot\n",
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(15, 6))\n",
    "townships.plot(ax=ax1, color='lightblue', edgecolor='black')\n",
    "ax1.set_title('Townships')\n",
    "counties.plot(ax=ax2, color='lightgreen', edgecolor='black')\n",
    "ax2.set_title('Counties (Dissolved)')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Lab 2: Raster Data Fundamentals"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Check for DEM data\n",
    "import os\n",
    "from glob import glob\n",
    "\n",
    "# Search for DEM files\n",
    "dem_files = glob('**/*.tif', recursive=True) + glob('**/*.tiff', recursive=True)\n",
    "dem_files.extend(glob('**/*dem*', recursive=True))\n",
    "dem_files.extend(glob('**/*DEM*', recursive=True))\n",
    "\n",
    "print(\"Searching for DEM files...\")\n",
    "if dem_files:\n",
    "    print(f\"Found potential DEM files: {dem_files}\")\n",
    "else:\n",
    "    print(\"❌ No DEM files found. Creating sample DEM...\")\n",
    "    \n",
    "    # Create sample DEM for Hualien area\n",
    "    import xarray as xr\n",
    "    \n",
    "    # Create sample elevation data\n",
    "    x = np.linspace(120.8, 121.8, 100)\n",
    "    y = np.linspace(23.0, 24.0, 100)\n",
    "    \n",
    "    # Create realistic terrain (mountainous)\n",
    "    xx, yy = np.meshgrid(x, y)\n",
    "    elevation = 100 + 2000 * np.exp(-((xx-121.3)**2 + (yy-23.6)**2) / 0.1) + \\\n",
    "                500 * np.sin(xx*10) * np.cos(yy*10) + \\\n",
    "                np.random.normal(0, 50, xx.shape)\n",
    "    \n",
    "    # Create xarray DataArray\n",
    "    dem = xr.DataArray(\n",
    "        elevation,\n",
    "        coords={'x': x, 'y': y},\n",
    "        dims=['y', 'x'],\n",
    "        attrs={'crs': 'EPSG:4326'}\n",
    "    )\n",
    "    \n",
    "    # Save as GeoTIFF\n",
    "    dem.rio.to_raster('hualien_sample_dem.tif')\n",
    "    print(\"✅ Created sample DEM: hualien_sample_dem.tif\")\n",
    "    \n",
    "    dem_file = 'hualien_sample_dem.tif'\n",
    "else:\n",
    "    dem_file = dem_files[0]  # Use first found DEM file"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load DEM with rioxarray\n",
    "dem = rxr.open_rasterio(dem_file)\n",
    "print(f\"DEM Info:\")\n",
    "print(f\"Shape: {dem.shape}\")\n",
    "print(f"CRS: {dem.rio.crs}\")\n",
    "print(f\"Bounds: {dem.rio.bounds()}\")\n",
    "print(f\"Resolution: {dem.rio.resolution()}\")\n",
    "print(f\"Data type: {dem.dtype}\")\n",
    "print(f\"Elevation range: {dem.min().values:.1f} - {dem.max().values:.1f}m\")\n",
    "\n",
    "# Plot DEM\n",
    "plt.figure(figsize=(12, 8))\n",
    "dem.plot(cmap='terrain', robust=True)\n",
    "plt.title('Digital Elevation Model (DEM)')\n",
    "plt.xlabel('Longitude')\n",
    "plt.ylabel('Latitude')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## DEM as NumPy Array with Spatial Metadata"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Access DEM as NumPy array\n",
    "dem_array = dem.values\n",
    "print(f\"DEM as NumPy array:\")\n",
    "print(f\"Type: {type(dem_array)}\")\n",
    "print(f\"Shape: {dem_array.shape}\")\n",
    "print(f\"Min: {dem_array.min():.1f}m\")\n",
    "print(f\"Max: {dem_array.max():.1f}m\")\n",
    "print(f\"Mean: {dem_array.mean():.1f}m\")\n",
    "\n",
    "# Access spatial metadata\n",
    "print(f\"\\nSpatial Metadata:\")\n",
    "print(f\"Transform: {dem.rio.transform()}\")\n",
    "print(f\"CRS: {dem.rio.crs}\")\n",
    "print(f\"Nodata: {dem.rio.nodata}\")\n",
    "\n",
    "# Show that it's a NumPy array with geospatial context\n",
    "print(f\"\\nDemonstrating NumPy operations:\")\n",
    "high_elevation = dem_array > 1000  # Boolean array\n",
    "print(f\"Areas above 1000m: {high_elevation.sum()} pixels\")\n",
    "print(f\"Percentage above 1000m: {high_elevation.mean()*100:.1f}%\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Lab 3: Compute Terrain Slope from DEM"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compute slope using numpy gradient\n",
    "def compute_slope(dem_data, pixel_size_x, pixel_size_y):\n",
    "    \"\"\"\n",
    "    Compute slope from DEM using numpy gradient\n",
    "    Returns slope in degrees\n",
    "    \"\"\"\n",
    "    # Compute gradients\n",
    "    dy, dx = np.gradient(dem_data, pixel_size_y, pixel_size_x)\n",
    "    \n",
    "    # Compute slope in radians\n",
    "    slope_rad = np.arctan(np.sqrt(dx**2 + dy**2))\n",
    "    \n",
    "    # Convert to degrees\n",
    "    slope_deg = np.degrees(slope_rad)\n",
    "    \n",
    "    return slope_deg\n",
    "\n",
    "# Get pixel size from DEM metadata\n",
    "res_x, res_y = abs(dem.rio.resolution()[0]), abs(dem.rio.resolution()[1])\n",
    "print(f\"Pixel size: {res_x:.6f} x {res_y:.6f} degrees\")\n",
    "\n",
    "# Convert to meters (approximate)\n",
    "# 1 degree ≈ 111,320 meters\n",
    "pixel_size_x_m = res_x * 111320\n",
    "pixel_size_y_m = res_y * 111320\n",
    "print(f\"Pixel size: {pixel_size_x_m:.1f} x {pixel_size_y_m:.1f} meters\")\n",
    "\n",
    "# Compute slope\n",
    "slope_deg = compute_slope(dem.values.squeeze(), pixel_size_x_m, pixel_size_y_m)\n",
    "\n",
    "print(f\"\\nSlope Statistics:\")\n",
    "print(f\"Min slope: {np.nanmin(slope_deg):.2f}°\")\n",
    "print(f\"Max slope: {np.nanmax(slope_deg):.2f}°\")\n",
    "print(f\"Mean slope: {np.nanmean(slope_deg):.2f}°\")\n",
    "\n",
    "# Create slope xarray for plotting\n",
    "slope_xr = xr.DataArray(\n",
    "    slope_deg,\n",
    "    coords=dem.coords,\n",
    "    dims=dem.dims,\n",
    "    attrs={'crs': dem.rio.crs, 'units': 'degrees'}\n",
    ")\n",
    "\n",
    "# Plot slope\n",
    "plt.figure(figsize=(12, 8))\n",
    "slope_xr.plot(cmap='YlOrRd', robust=True, vmin=0, vmax=45)\n",
    "plt.title('Terrain Slope (Degrees)')\n",
    "plt.xlabel('Longitude')\n",
    "plt.ylabel('Latitude')\n",
    "plt.colorbar(label='Slope (degrees)')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Lab 4: Zonal Statistics - Extract Raster Values into Vector Shapes"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load Hualien county townships (or use sample)\n",
    "try:\n",
    "    # Try to filter Hualien townships\n",
    "    hualien_towns = townships[townships['COUNTYNAME'].str.contains('花蓮', na=False)].copy()\n",
    "    if len(hualien_towns) == 0:\n",
    "        raise ValueError(\"No Hualien found\")\n",
    "except:\n",
    "    # Use sample area around DEM\n",
    "    print(\"Using sample area around DEM...\")\n",
    "    # Create sample polygons for demonstration\n",
    "    from shapely.geometry import Polygon\n",
    "    \n",
    "    bounds = dem.rio.bounds()\n",
    "    sample_polys = [\n",
    "        Polygon([(bounds[0], bounds[1]), (bounds[2], bounds[1]), \n",
    "                (bounds[2], bounds[3]), (bounds[0], bounds[3])]),  # Full extent\n",
    "        Polygon([(bounds[0], bounds[1]), (bounds[0]+(bounds[2]-bounds[0])/2, bounds[1]),\n",
    "                (bounds[0]+(bounds[2]-bounds[0])/2, bounds[1]+(bounds[3]-bounds[1])/2),\n",
    "                (bounds[0], bounds[1]+(bounds[3]-bounds[1])/2)]),  # Bottom-left quadrant\n",
    "        Polygon([(bounds[0]+(bounds[2]-bounds[0])/2, bounds[1]+(bounds[3]-bounds[1])/2), \n",
    "                (bounds[2], bounds[1]+(bounds[3]-bounds[1])/2),\n",
    "                (bounds[2], bounds[3]), (bounds[0]+(bounds[2]-bounds[0])/2, bounds[3])])  # Top-right quadrant\n",
    "    ]\n",
    "    \n",
    "    hualien_towns = gpd.GeoDataFrame({\n",
    "        'TOWNNAME': ['Full Area', 'West Zone', 'East Zone'],\n",
    "        'COUNTYNAME': ['Sample', 'Sample', 'Sample'],\n",
    "        'geometry': sample_polys\n",
    "    }, crs=dem.rio.crs)\n",
    "\n",
    "print(f\"Using {len(hualien_towns)} zones for zonal statistics\")\n",
    "print(hualien_towns[['TOWNNAME', 'geometry']].head())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Method 1: Using rasterstats\n",
    "from rasterstats import zonal_stats\n",
    "\n",
    "print(\"=== Zonal Statistics with rasterstats ===\")\n",
    "\n",
    "# Compute zonal statistics for elevation\n",
    "elevation_stats = zonal_stats(\n",
    "    hualien_towns, \n",
    "    dem_file, \n",
    "    stats=['count', 'mean', 'min', 'max', 'std', 'median'],\n",
    "    geojson_out=True\n",
    ")\n",
    "\n",
    "# Convert to GeoDataFrame\n",
    "elevation_gdf = gpd.GeoDataFrame.from_features(elevation_stats)\n",
    "elevation_gdf.crs = hualien_towns.crs\n",
    "\n",
    "print(\"Elevation Statistics:\")\n",
    "for idx, row in elevation_gdf.iterrows():\n",
    "    town_name = hualien_towns.iloc[idx]['TOWNNAME']\n",
    "    print(f\"{town_name}: mean={row['mean']:.1f}m, min={row['min']:.1f}m, max={row['max']:.1f}m\")\n",
    "\n",
    "# Compute zonal statistics for slope\n",
    "# Save slope as temporary file for rasterstats\n",
    "slope_xr.rio.to_raster('temp_slope.tif')\n",
    "\n",
    "slope_stats = zonal_stats(\n",
    "    hualien_towns,\n",
    "    'temp_slope.tif',\n",
    "    stats=['count', 'mean', 'min', 'max', 'std', 'median'],\n",
    "    geojson_out=True\n",
    ")\n",
    "\n",
    "slope_gdf = gpd.GeoDataFrame.from_features(slope_stats)\n",
    "slope_gdf.crs = hualien_towns.crs\n",
    "\n",
    "print(\"\\nSlope Statistics:\")\n",
    "for idx, row in slope_gdf.iterrows():\n",
    "    town_name = hualien_towns.iloc[idx]['TOWNNAME']\n",
    "    print(f\"{town_name}: mean={row['mean']:.2f}°, min={row['min']:.2f}°, max={row['max']:.2f}°\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Method 2: Using rioxarray clip + numpy\n",
    "print(\"\\n=== Zonal Statistics with rioxarray + numpy ===\")\n",
    "\n",
    "def compute_zonal_stats_rasterio(vector_gdf, raster_xr, stat_name):\n",
    "    \"\"\"\n",
    "    Compute zonal statistics using rioxarray clipping\n",
    "    \"\"\"\n",
    "    stats = []\n",
    "    \n",
    "    for idx, row in vector_gdf.iterrows():\n",
    "        # Clip raster to polygon\n",
    "        clipped = raster_xr.rio.clip([row.geometry], raster_xr.rio.crs, drop=True)\n",
    "        \n",
    "        # Remove nodata values\n",
    "        valid_data = clipped.values[~np.isnan(clipped.values)]\n",
    "        \n",
    "        if len(valid_data) > 0:\n",
    "            stats.append({\n",
    "                'town': row['TOWNNAME'],\n",
    "                'count': len(valid_data),\n",
    "                'mean': np.mean(valid_data),\n",
    "                'min': np.min(valid_data),\n",
    "                'max': np.max(valid_data),\n",
    "                'std': np.std(valid_data),\n",
    "                'median': np.median(valid_data)\n",
    "            })\n",
    "        else:\n",
    "            stats.append({\n",
    "                'town': row['TOWNNAME'],\n",
    "                'count': 0,\n",
    "                'mean': np.nan,\n",
    "                'min': np.nan,\n",
    "                'max': np.nan,\n",
    "                'std': np.nan,\n",
    "                'median': np.nan\n",
    "            })\n",
    "    \n",
    "    return pd.DataFrame(stats)\n",
    "\n",
    "# Compute stats for both elevation and slope\n",
    "elevation_stats_rio = compute_zonal_stats_rasterio(hualien_towns, dem, 'elevation')\n",
    "slope_stats_rio = compute_zonal_stats_rasterio(hualien_towns, slope_xr, 'slope')\n",
    "\n",
    "print(\"Elevation Stats (rioxarray method):\")\n",
    "print(elevation_stats_rio.round(2))\n",
    "\n",
    "print(\"\\nSlope Stats (rioxarray method):\")\n",
    "print(slope_stats_rio.round(2))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Visualization: Combined Vector-Raster Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create comprehensive visualization\n",
    "fig, ((ax1, ax2), (ax3, ax4)) = plt.subplots(2, 2, figsize=(16, 12))\n",
    "\n",
    "# Plot 1: DEM with boundaries\n",
    "dem.plot(ax=ax1, cmap='terrain', robust=True, alpha=0.8)\n",
    "hualien_towns.plot(ax=ax1, facecolor='none', edgecolor='red', linewidth=2)\n",
    "ax1.set_title('DEM with Zone Boundaries')\n",
    "\n",
    "# Plot 2: Slope with boundaries\n",
    "slope_xr.plot(ax=ax2, cmap='YlOrRd', robust=True, alpha=0.8, vmin=0, vmax=45)\n",
    "hualien_towns.plot(ax=ax2, facecolor='none', edgecolor='black', linewidth=2)\n",
    "ax2.set_title('Slope with Zone Boundaries')\n",
    "\n",
    "# Plot 3: Elevation statistics bar chart\n",
    "elevation_stats_rio.set_index('town')['mean'].plot(kind='bar', ax=ax3, color='brown')\n",
    "ax3.set_title('Mean Elevation by Zone')\n",
    "ax3.set_ylabel('Elevation (m)')\n",
    "ax3.tick_params(axis='x', rotation=45)\n",
    "\n",
    "# Plot 4: Slope statistics bar chart\n",
    "slope_stats_rio.set_index('town')['mean'].plot(kind='bar', ax=ax4, color='orange')\n",
    "ax4.set_title('Mean Slope by Zone')\n",
    "ax4.set_ylabel('Slope (degrees)')\n",
    "ax4.tick_params(axis='x', rotation=45)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('vector_raster_integration.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"✅ Saved comprehensive visualization as 'vector_raster_integration.png'\")"
   ]
  },
