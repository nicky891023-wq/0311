# ARIA Project Environment Variables
# Copy this file to .env and modify as needed

# Buffer distances in meters for risk assessment
BUFFER_HIGH=500
BUFFER_MED=1000
BUFFER_LOW=2000

# Target county for analysis (use 'ALL' for nationwide)
TARGET_COUNTY=ALL

# Target coordinate reference system
TARGET_CRS=EPSG:3826

# Data source URLs
river_url=https://gic.wra.gov.tw/Gis/gic/API/Google/DownLoad.aspx?fname=RIVERPOLY&filetype=SHP
tgos_url=https://www.tgos.tw/tgos/VirtualDir/Product/3fe61d4a-ca23-4f45-8aca-4a536f40f290/

# Output file paths
map_file=outputs/risk_map.html
chart_file=outputs/risk_analysis.png
json_file=outputs/shelter_risk_audit.json
